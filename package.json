{
  "name": "@hydra-acp/transformer",
  "version": "0.0.1",
  "description": "JS-injected hooks for hydra-acp — drop a .config.js file or build a custom transformer with the SDK.",
  "license": "MIT",
  "type": "module",
  "publishConfig": { "access": "public", "registry": "https://registry.npmjs.org" },
  "files": ["dist", "README.md", "LICENSE"],
  "main": "dist/lib.js",
  "bin": {
    "hydra-acp-transformer": "dist/index.js"
  },
  "exports": {
    ".":         { "import": "./dist/lib.js", "types": "./dist/lib.d.ts" },
    "./types":   { "import": "./dist/types.js", "types": "./dist/types.d.ts" }
  },
  "scripts": {
    "build": "npm run lint && tsup",
    "watch": "tsup --watch",
    "start": "node dist/index.js",
    "dev": "tsup && node dist/index.js",
    "test": "node --test --import tsx 'test/**/*.test.ts'",
    "lint": "tsc -p . --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ws":   "^8.20.0",
    "jiti": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.0",
    "typescript": "^5.6.3"
  }
}
